
ENV="test"

SERV="enkas.eu"
CONN=""
CONT_PREFIX="cont"
REGISTRY="registry.enkas.eu"
NOTLS="--tls-verify=false "
NOTLS_PORT=":5000"
REGISTRY_NOTLS="$NOTLS$REGISTRY$NOTLS_PORT"
PORT="$NOTLS_PORT"
NTLS="$NOTLS"
NC='\033[0m' # No Color
C0='\033[0;31m' #Black        0;30     Dark Gray     1;30
C1='\033[0;31m' #Red          0;31     Light Red     1;31
C2='\033[0;32m' #Green        0;32     Light Green   1;32
C3='\033[0;33m' #Brown/Orange 0;33     Yellow        1;33
C4='\033[0;34m' #Blue         0;34     Light Blue    1;34
C5='\033[0;35m' #Purple       0;35     Light Purple  1;35
C6='\033[0;36m' #Cyan         0;36     Light Cyan    1;36
C7='\033[0;37m' #Light Gray   0;37     White         1;37
